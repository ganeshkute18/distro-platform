# ─────────────────────────────────────────────────────────────────────────────
# DISTRO PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values before running.
#
# 🔐 GENERATING STRONG SECRETS (run in terminal):
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️  NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# DATABASE (Required)
# ─────────────────────────────────────────
# Local dev:
DATABASE_URL="postgresql://distro_user:distro_pass@localhost:5432/distro_platform?schema=public"
# Railway example:
# DATABASE_URL="postgresql://postgres:xxxxx@monorail.proxy.rlwy.net:12345/railway"
# AWS RDS example:
# DATABASE_URL="postgresql://admin:xxxxx@your-rds.us-east-1.rds.amazonaws.com:5432/distro_platform"

# ─────────────────────────────────────────
# JWT SECRETS (Required — generate fresh values for production!)
# ─────────────────────────────────────────
# ⛔ CHANGE THESE before deploying — use the command above to generate
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────
# API SERVER (Required)
# ─────────────────────────────────────────
API_PORT=4000
API_PREFIX="api/v1"
# Production: set to your real frontend domain
CORS_ORIGINS="http://localhost:3000"
# CORS_ORIGINS="https://your-domain.com"

# ─────────────────────────────────────────
# FRONTEND URL (Required for email verification links)
# ─────────────────────────────────────────
# Development:
FRONTEND_URL="http://localhost:3000"
# Production: MUST match your actual deployed URL
# FRONTEND_URL="https://your-domain.com"

# ─────────────────────────────────────────
# FRONTEND (Next.js)
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
NEXTAUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_API_URL="https://api.your-domain.com/api/v1"
# NEXTAUTH_URL="https://your-domain.com"

# ─────────────────────────────────────────
# EMAIL PROVIDER (Required for user email verification)
# ─────────────────────────────────────────
# Without this, verification emails are only logged to console (dev mode).
# In production, real users will NOT receive their verification email.
#
# Option 1: SendGrid (recommended, free tier: 100 emails/day)
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="noreply@yourdomain.com"
# EMAIL_FROM_NAME="DistroPro"
#
# Option 2: Mailgun
# MAILGUN_API_KEY="key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# MAILGUN_DOMAIN="mg.yourdomain.com"
#
# Option 3: AWS SES
# AWS_SES_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXXXX"
# AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─────────────────────────────────────────
# CLOUDINARY (Optional — for product image uploads)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─────────────────────────────────────────
# REDIS (Optional — for future queues/caching)
# ─────────────────────────────────────────
# REDIS_URL="redis://localhost:6379"
