# ─────────────────────────────────────────────────────────────────────────────
# DISTRO PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values before running.
#
# 🔐 GENERATING STRONG SECRETS (run in terminal):
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ⚠️  NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# DATABASE (Required)
# ─────────────────────────────────────────
# Local dev:
DATABASE_URL="postgresql://distro_user:distro_pass@localhost:5432/distro_platform?schema=public"
# Railway example:
# DATABASE_URL="postgresql://postgres:xxxxx@monorail.proxy.rlwy.net:12345/railway"
# AWS RDS example:
# DATABASE_URL="postgresql://admin:xxxxx@your-rds.us-east-1.rds.amazonaws.com:5432/distro_platform"

# ─────────────────────────────────────────
# JWT SECRETS (Required — generate fresh values for production!)
# ─────────────────────────────────────────
# ⛔ CHANGE THESE before deploying — use the command above to generate
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────
# API SERVER (Required)
# ─────────────────────────────────────────
API_PORT=4000
API_PREFIX="api/v1"
# Production: set to your real frontend domain
CORS_ORIGINS="http://localhost:3000"
# CORS_ORIGINS="https://your-domain.com"

# ─────────────────────────────────────────
# FRONTEND URL (Required for email verification links)
# ─────────────────────────────────────────
# Development:
FRONTEND_URL="http://localhost:3000"
# Production: MUST match your actual deployed URL
# FRONTEND_URL="https://your-domain.com"

# ─────────────────────────────────────────
# FRONTEND (Next.js)
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
NEXTAUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_API_URL="https://api.your-domain.com/api/v1"
# NEXTAUTH_URL="https://your-domain.com"

# ─────────────────────────────────────────
# EMAIL — Resend (https://resend.com)
# Free tier: 3,000 emails/month · No credit card needed
# ─────────────────────────────────────────
# Without RESEND_API_KEY, emails are only logged to console (dev behaviour).
# In production, new users CANNOT verify their email without this set.
#
# 1. Sign up free at https://resend.com
# 2. Create an API key (Dashboard → API Keys → Create)
# 3. Paste it below
#
# NOTE: Without a verified domain, Resend sends FROM onboarding@resend.dev
# (works fine for testing). Add your domain later for a branded from-address.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="DistroPro <onboarding@resend.dev>"
# After adding your domain in Resend dashboard:
# EMAIL_FROM="DistroPro <noreply@yourdomain.com>"

# ─────────────────────────────────────────
# CLOUDINARY (Optional — for product image uploads)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─────────────────────────────────────────
# REDIS (Optional — for future queues/caching)
# ─────────────────────────────────────────
# REDIS_URL="redis://localhost:6379"
