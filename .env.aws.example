# DistroPro — AWS bootstrap (copy to .env.aws, never commit .env.aws)
export EC2_IP="your-ec2-public-ip"
export EC2_KEY="~/.ssh/your-key.pem"
export EC2_USER="ec2-user"

export RDS_HOST="your-rds-endpoint.ap-south-1.rds.amazonaws.com"
export RDS_PORT="5432"
export RDS_USER="distro_admin"
export RDS_PASS="your-rds-password"
export RDS_DB="distro_platform"

export API_BASE="http://${EC2_IP}:4000/api/v1"

# API domain for HTTPS production access
export API_DOMAIN="api.distropro.in"
export CERTBOT_EMAIL="admin@distropro.in"

# CORS configuration for frontend — set this to the actual browser origin of your frontend app
# Example: CORS_ORIGINS="https://distropro.in"
# Example for Vercel preview or alternate domain:
# CORS_ORIGINS="https://distropro.in,https://distro-platform.vercel.app"
export CORS_ORIGINS="https://your-frontend-domain.com"

# Optional: non-interactive bootstrap (bootstrap-post-migrate.sh)
# export PA_EMAIL="platform@distropro.in"
# export PA_PASS="min-12-char-password"
# export OWNER_EMAIL="owner@example.com"
# export OWNER_PASS="min-8-char-password"
